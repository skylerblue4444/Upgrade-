<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stake SKY444 • ShadowChat</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/static/css/style.css">
</head>
<body class="bg-[#0a0a2a] text-white p-6">
    <h1 class="text-4xl font-bold mb-8 neon-purple">Stake SKY444 – Earn up to 44.4% APY</h1>
    <div class="bg-[#1a0b3d] rounded-3xl p-8">
        <button onclick="window.stakingManager.stake(1000, 90)" class="w-full bg-purple-600 py-6 rounded-3xl text-2xl font-bold mb-4">Stake 1,000 SKY444 for 90 days</button>
        <p class="text-center text-purple-400">Sky Cycle bonus every 444 blocks • Longer lock = higher multiplier</p>
    </div>
</body>
</html>